{
  "name": "@workspace/pos-electron",
  "version": "1.0.0",
  "private": true,
  "description": "LibraryOS POS - Electron desktop app for cashiers",
  "main": "dist/main/electron/main.js",
  "scripts": {
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "pnpm build:renderer && pnpm build:main",
    "package:linux": "pnpm build && electron-builder --linux",
    "package:win": "pnpm build && electron-builder --win",
    "package:mac": "pnpm build && electron-builder --mac",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "vite": "catalog:"
  },
  "build": {
    "appId": "jo.libraryos.pos",
    "productName": "LibraryOS POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "executableName": "libraryos-pos",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "executableName": "libraryos-pos"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "publish": {
      "provider": "github",
      "owner": "libraryos",
      "repo": "pos-releases"
    },
    "nativeRebuilder": "sequential"
  }
}
