# ──────────────────────────────────────────────
#  LibraryOS — API Server — متغيرات البيئة
#  انسخ هذا الملف وسمّه .env ثم عدّل القيم
# ──────────────────────────────────────────────

# قاعدة البيانات PostgreSQL (مطلوب)
# مثال محلي:
DATABASE_URL=postgresql://postgres:password@localhost:5432/libraryos
# مثال Supabase أو Neon (مجاني على الإنترنت):
# DATABASE_URL=postgresql://user:password@db.xxxx.supabase.co:5432/postgres

# منفذ الخادم (مطلوب)
PORT=8080

# بيئة التشغيل
NODE_ENV=development
